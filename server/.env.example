PORT=3001
NODE_ENV=development

# Use "postgres" for Atomidata VM/Postgres, or "sqlite" for local fallback.
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./data/carecall.db

# Example Atomidata/Postgres URL:
# DATABASE_PROVIDER=postgres
# DATABASE_URL=postgres://carecall:password@127.0.0.1:5432/carecall
# DATABASE_SSL=false

CUSTOMER_NAME=Casimir

# Optional fallback token for local/manual webhook tests. If set and no
# ElevenLabs webhook secret is configured, requests must include this token
# either as ?token=... or in the x-carecall-webhook-token header.
ELEVENLABS_WEBHOOK_TOKEN=

# ElevenLabs post-call webhook signing secret. Real ElevenLabs webhooks include
# an ElevenLabs-Signature header that is verified against this secret.
ELEVENLABS_WEBHOOK_SECRET=

# Frontend origin for local development. Use "*" only for a hackathon demo if needed.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
